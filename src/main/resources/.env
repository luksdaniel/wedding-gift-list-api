# DocumentDB
DOCUMENTDB_URI=mongodb://username:password@your-documentdb-cluster.docdb.amazonaws.com:27017/yourdb?ssl=true&replicaSet=rs0&readPreference=secondaryPreferred&retryWrites=false
DOCUMENTDB_DATABASE=yourdb

# AWS S3
AWS_S3_BUCKET=your-bucket-name
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key